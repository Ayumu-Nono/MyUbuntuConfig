{
  "glassit.alpha": 255,
  "glassit.step": 220,
  "editor.fontFamily": "Monaco",
  "editor.fontLigatures": true,
  "window.newWindowDimensions": "fullscreen",
  "window.openFilesInNewWindow": "default",
  "window.restoreFullscreen": true,
  "workbench.startupEditor": "newUntitledFile",
  "explorer.confirmDelete": false,
  "javascript.suggest.autoImports": false,
  "typescript.suggest.autoImports": false,
  "python.linting.pylintEnabled": false,
  "python.linting.flake8Enabled": true,
  "editor.formatOnSave": true,
  "python.linting.mypyEnabled": true,
  "[go]": {},
  "python.formatting.provider": "black",
  "go.formatTool": "goimports",
  "python.linting.flake8Args": [
    "--ignore=E203"
  ],
  "vscode-neovim.neovimExecutablePaths.linux": "/usr/bin/nvim",
  "vscode-neovim.compositeKeys": {
    "jj": {
      "command": "vscode-neovim.escape",
    },
  },
  "[html]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "files.associations": {
    "*.html": "jinja-html"
  },
  "keyboard.dispatch": "keyCode",
  "fortran.gfortranExecutable": "/usr/bin/gfortran",
  "workbench.iconTheme": "material-icon-theme",
  // latex
  "latex-workshop.latex.tools": [
    {
      "command": "pbibtex",
      "args": [
        "%DOCFILE%",
        "-kanji=utf8"
      ],
      "name": "pbibtex"
    },
    {
      "name": "ptex2pdf",
      "command": "ptex2pdf",
      "args": [
        "-interaction=nonstopmode",
        "-l",
        "-ot",
        "-kanji=utf8 -synctex=1",
        "%DOC%",
      ]
    },
  ],
  "latex-workshop.view.pdf.viewer": "tab",
  "terminal.integrated.fontFamily": "monospace",
  "latex-workshop.message.update.show": false,
  "latex-workshop.latex.recipes": [
    {
      "name": "ptex2pdf*2",
      "tools": [
        // "ptex2pdf",
        // "ptex2pdf",
        "ptex2pdf",
        "pbibtex",
        "ptex2pdf",
        "ptex2pdf"
      ]
    },
  ],
  "latex-workshop.latex.autoBuild.run": "onFileChange",
  "latex-workshop.latex.autoClean.run": "onFailed",
  "latex-workshop.latex.build.clearLog.everyRecipeStep.enabled": false,
  "javascript.updateImportsOnFileMove.enabled": "always",
  "typescript.updateImportsOnFileMove.enabled": "always",
  "fortran-ls.autocompletePrefix": true,
  "fortran-ls.hoverSignature": true,
  "fortran-ls.variableHover": true,
  "python.languageServer": "Pylance",
  "python.analysis.extraPaths": [
    "DoNotTouchThisFolder"
  ],
  "editor.suggestSelection": "first",
  "vsintellicode.modify.editor.suggestSelection": "automaticallyOverrodeDefaultValue",
  "workbench.editorAssociations": {
    "*.ipynb": "jupyter-notebook"
  },
  "diffEditor.ignoreTrimWhitespace": false,
  "vsicons.dontShowNewVersionMessage": true,
  "terminal.integrated.tabs.enabled": true,
  "editor.cursorStyle": "line",
  "editor.insertSpaces": false,
  "editor.lineNumbers": "on",
  "editor.wordSeparators": "/\\()\"':,.;<>~!@#$%^&*|+=[]{}`?-",
  "editor.wordWrap": "off",
  "notebook.cellToolbarLocation": {
    "default": "right",
    "jupyter-notebook": "left"
  },
  "githubIssues.queries": [
    {
      "label": "My Issues",
      "query": "default"
    },
    {
      "label": "Created Issues",
      "query": "author:${user} state:open repo:${owner}/${repository} sort:created-desc"
    }
  ],
  "[python]": {
    "editor.wordBasedSuggestions": "off",
    "editor.formatOnType": true
  },
  "git.suggestSmartCommit": false,
  "[cpp]": {
    "editor.wordBasedSuggestions": "off",
    "editor.suggest.insertMode": "replace",
    "editor.semanticHighlighting.enabled": true
  },
  "explorer.confirmDragAndDrop": false,
  "jupyter.askForKernelRestart": false,
  "git.ignoreLegacyWarning": true,
  "git.confirmSync": false,
  "markdown.preview.fontSize": 10,
  "terminal.integrated.fontSize": 15,
  "window.zoomLevel": 0,
  "editor.inlineSuggest.enabled": true,
  "github.copilot.enable": {
    "*": true,
    "plaintext": false,
    "markdown": false,
    "scminput": false
  },
  "github.copilot.editor.enableAutoCompletions": true,
  "accessibility.signals.lineHasError": {
    "sound": "off"
  },
  "accessibility.signals.lineHasBreakpoint": {
    "sound": "off"
  },
  "accessibility.signals.diffLineInserted": {
    "sound": "off"
  },
  "accessibility.signals.diffLineDeleted": {
    "sound": "off"
  },
  "accessibility.signals.diffLineModified": {
    "sound": "off"
  },
  "accessibility.signals.progress": {
    "sound": "off"
  },
  "extensions.ignoreRecommendations": true,
  "editor.accessibilitySupport": "off",
  "github.copilot.nextEditSuggestions.enabled": true,
  "python.defaultInterpreterPath": "/home/linuxbrew/.linuxbrew/bin/python3",
  "files.autoSave": "afterDelay",
}